# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/solnut-neet?retryWrites=true&w=majority
MONGODB_TEST_URI=mongodb+srv://username:password@cluster.mongodb.net/solnut-neet-test?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRE=7d

# AI & OCR
# Set AI_PROVIDER to one of: bedrock | gemini | openai
AI_PROVIDER=bedrock

# AWS Bedrock (recommended — most token-efficient)
# Enable the model you want in AWS Bedrock Console → Model Access (us-east-1)
# Most token-efficient options:
#   amazon.nova-lite-v1:0                        -- cheapest, fast JSON tasks (default)
#   amazon.nova-pro-v1:0                         -- better reasoning, moderate cost
#   anthropic.claude-3-5-haiku-20241022-v1:0     -- best quality/cost balance
#   anthropic.claude-3-haiku-20240307-v1:0       -- older Haiku, very cheap
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# OpenAI (alternative)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Gemini (alternative)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
PDF_UPLOAD_LIMIT_MB=100
IMAGE_UPLOAD_LIMIT_MB=8
# PDF upload parses questions locally. Use POST /api/questions/classify for batched AI metadata.
PDF_IMPORT_AI_FALLBACK=false
SCANNED_PDF_AI_IMPORT=false
SCANNED_PDF_LOCAL_OCR=false
PDF_RENDERER_PATH=pdftoppm
OCR_MAX_PAGES=20
OCR_DPI=200

# Cloudinary (Image Storage)
CLOUDINARY_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Socket.io
SOCKET_PORT=5001

# Email (for notifications)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SERVICE=gmail

# Admin Panel
ADMIN_EMAIL=admin@solnut.local
ADMIN_PASSWORD=change_me_in_production

# Logging
LOG_LEVEL=debug
